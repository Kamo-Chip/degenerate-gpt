# Neon Postgres connection string (pooled or direct)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# OpenAI — Decider Agent + the Social/Market research loops (via the Vercel AI SDK)
OPENAI_API_KEY="sk-..."
# Optional: override the model (defaults to gpt-4o-mini)
OPENAI_MODEL="gpt-5.5-2026-04-23"

# football-data.org — free API key for fixtures/standings/form (Stats agent + discovery)
FOOTBALL_DATA_API_KEY=""

# Tavily — web + news search used by the Social/Market research agents
TAVILY_API_KEY=""

# Optional: override the eloratings.net TSV source (Stats agent, best-effort)
# ELO_RATINGS_TSV_URL="https://www.eloratings.net/World.tsv"

# Polymarket Gamma API needs no key (public, read-only).

# Trigger.dev — set automatically by `trigger.dev login` for local dev.
# Required by apps/web to trigger runs from the dashboard, and when deploying apps/jobs:
TRIGGER_SECRET_KEY="tr_..."

# --- apps/web: accounts (Better Auth + Resend magic links) ---
# 32+ char random secret, e.g. `openssl rand -hex 32`
BETTER_AUTH_SECRET=""
# Base URL of the web app (used to build magic-link callbacks)
BETTER_AUTH_URL="http://localhost:3000"
# Resend API key + verified sender for magic-link emails
RESEND_API_KEY="re_..."
EMAIL_FROM="degenerate·gpt <onboarding@resend.dev>"
# Where users are pointed once they hit the free prediction cap (clone & self-host)
NEXT_PUBLIC_REPO_URL="https://github.com/your-username/degenerate-gpt"
