{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@degenerate-gpt/shared": ["./packages/shared/src/index.ts"],
      "@degenerate-gpt/db": ["./packages/db/src/index.ts"],
      "@degenerate-gpt/agents": ["./packages/agents/src/index.ts"],
      "@degenerate-gpt/sources": ["./packages/sources/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/*.config.ts",
    "apps/*/src/**/*.ts",
    "apps/*/*.config.ts"
  ],
  "exclude": ["apps/web"]
}
